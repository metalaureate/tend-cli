{
  "name": "tend-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Tend event relay — Cloudflare Worker backed by D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 execute tend-relay-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute tend-relay-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250310.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.0.0"
  }
}
