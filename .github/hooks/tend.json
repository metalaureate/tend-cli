{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "/Users/possum/bin/tend hook session-start",
        "env": {
          "TEND_HOOK_DEBUG": "1"
        }
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "/Users/possum/bin/tend hook user-prompt",
        "env": {
          "TEND_HOOK_DEBUG": "1"
        }
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "/Users/possum/bin/tend hook stop",
        "env": {
          "TEND_HOOK_DEBUG": "1"
        }
      }
    ]
  }
}
