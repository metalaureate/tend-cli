#!/usr/bin/env bash
# Tend — a pull-based CLI for developers running multiple AI agents.
# "What's running? What needs me?"

set -euo pipefail

TEND_VERSION="0.1.0"
TEND_ROOT="${TEND_ROOT:-$HOME/projects}"
TEND_HOOK_DEBUG="1"

# ─── Colors & Formatting ────────────────────────────────────────────────────

_tend_colors_enabled() {
  [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]
}

if _tend_colors_enabled; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_AMBER=$'\033[33m'
  C_CYAN=$'\033[36m'
  C_GREEN=$'\033[32m'
  C_RED=$'\033[31m'
  C_GREY=$'\033[90m'
else
  C_RESET="" C_BOLD="" C_DIM="" C_AMBER="" C_CYAN="" C_GREEN="" C_RED="" C_GREY=""
fi

# ─── Helpers ─────────────────────────────────────────────────────────────────

_tend_ts() {
  date -u +"%Y-%m-%dT%H:%M:%S"
}

_tend_ts_local() {
  date +"%Y-%m-%dT%H:%M:%S"
}

_tend_date_header() {
  date "+%a %b %d, %H:%M"
}

# Convert an ISO-8601 timestamp to epoch seconds (portable across macOS/Linux)
_tend_to_epoch() {
  local ts="$1"
  if date -j -f "%Y-%m-%dT%H:%M:%S" "$ts" "+%s" 2>/dev/null; then
    return
  fi
  date -d "$ts" "+%s" 2>/dev/null || echo "0"
}

# Format a duration in seconds to a human-readable string
_tend_format_duration() {
  local seconds="$1"
  if (( seconds < 0 )); then seconds=0; fi
  if (( seconds < 60 )); then
    echo "${seconds}s"
  elif (( seconds < 3600 )); then
    echo "$(( seconds / 60 ))m"
  elif (( seconds < 86400 )); then
    echo "$(( seconds / 3600 ))h"
  else
    echo "$(( seconds / 86400 ))d"
  fi
}

# Format how long ago a timestamp was
_tend_ago() {
  local ts="$1"
  local ts_epoch now_epoch delta
  ts_epoch=$(_tend_to_epoch "$ts")
  now_epoch=$(date "+%s")
  delta=$(( now_epoch - ts_epoch ))
  _tend_format_duration "$delta"
}

# Escape a string for use as a JSON string value (without surrounding quotes)
_tend_json_escape() {
  printf '%s' "$1" | awk '
    BEGIN { ORS="" }
    {
      gsub(/\\/, "\\\\")
      gsub(/"/, "\\\"")
      gsub(/\t/, "\\t")
      gsub(/\r/, "")
      if (NR > 1) printf "\\n"
      print
    }
  '
}

# Extract a field from JSON input (best-effort, no jq dependency)
_tend_extract_session_id() {
  local input="$1"
  # VS Code sends "session_id" (snake_case); also handle "sessionId" (camelCase) for compatibility
  printf '%s' "$input" | tr '\n' ' ' | sed -n 's/.*"session_id" *: *"\([^"]*\)".*/\1/p; s/.*"sessionId" *: *"\([^"]*\)".*/\1/p' | head -1
}

_tend_hook_debug() {
  if [[ -n "${TEND_HOOK_DEBUG:-}" ]]; then
    local hook_name="$1" input="$2"
    local project_path
    project_path=$(_tend_resolve_project_path "" 2>/dev/null) || return 0
    local log="$project_path/.tend/hook_debug.log"
    printf '%s [%s] %s\n' "$(_tend_ts_local)" "$hook_name" "$input" >> "$log"
  fi
}

TEND_REGISTRY="${HOME}/.tend/projects"

# Discover tended projects from the registry
_tend_discover_projects() {
  if [[ ! -f "$TEND_REGISTRY" ]]; then
    return
  fi
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    [[ -d "$path/.tend" ]] && echo "$path"
  done < "$TEND_REGISTRY"
}

# Register a project path in the registry
_tend_register_project() {
  local project_path="$1"
  # Canonicalize path to avoid case-mismatch duplicates on macOS
  if [[ -d "$project_path" ]]; then
    project_path=$(cd "$project_path" && pwd -P)
  fi
  mkdir -p "$(dirname "$TEND_REGISTRY")"
  if [[ ! -f "$TEND_REGISTRY" ]] || ! grep -qixF "$project_path" "$TEND_REGISTRY" 2>/dev/null; then
    echo "$project_path" >> "$TEND_REGISTRY"
  fi
}

# Get projects in board order (most recent first, current project pinned to top)
_tend_sorted_projects() {
  local projects
  projects=$(_tend_discover_projects) || true
  [[ -z "$projects" ]] && return

  local current_project_path=""
  local cur
  cur=$(pwd -P 2>/dev/null) || true
  while [[ "$cur" != "/" ]]; do
    if [[ -d "$cur/.git" ]]; then
      current_project_path="$cur"
      break
    fi
    cur="$(dirname "$cur")"
  done

  while IFS= read -r project; do
    [[ -z "$project" ]] && continue
    local ts_epoch=0
    local events_file="$project/.tend/events"
    if [[ -f "$events_file" ]]; then
      local last_line
      last_line=$(tail -1 "$events_file" 2>/dev/null) || true
      if [[ -n "$last_line" ]]; then
        local ts="${last_line%% *}"
        ts_epoch=$(_tend_to_epoch "$ts") || true
      fi
    fi
    if (( ts_epoch == 0 )) && [[ -d "$project/.git" ]]; then
      ts_epoch=$(git -C "$project" log -1 --format="%ct" 2>/dev/null) || true
      [[ -z "$ts_epoch" ]] && ts_epoch=0
    fi
    if [[ "$project" == "$current_project_path" ]]; then
      ts_epoch=9999999999
    fi
    printf '%s\t%s\n' "$ts_epoch" "$project"
  done <<< "$projects" | sort -t$'\t' -k1 -rn | cut -f2
}

# Resolve a project name to its full path.
# If an arg is given, match against registered projects (basename prefix then substring).
# If no arg, detect from $PWD by walking up to find .git.
_tend_resolve_project_path() {
  local name="${1:-}"

  if [[ -n "$name" ]]; then
    # Numeric shortcut: resolve board position to project path
    if [[ "$name" =~ ^[0-9]+$ ]]; then
      local nth="$name"
      local sorted
      sorted=$(_tend_sorted_projects)
      local idx=0
      while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        (( ++idx ))
        if (( idx == nth )); then
          echo "$path"
          return
        fi
      done <<< "$sorted"
      echo >&2 "tend: no project at position $nth"
      return 1
    fi

    # Check registry for matches
    if [[ -f "$TEND_REGISTRY" ]]; then
      local path bname
      # Exact basename match
      while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        bname=$(basename "$path")
        if [[ "$bname" == "$name" && -d "$path" ]]; then
          echo "$path"
          return
        fi
      done < "$TEND_REGISTRY"
      # Prefix match
      while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        bname=$(basename "$path")
        if [[ "$bname" == "$name"* && -d "$path" ]]; then
          echo "$path"
          return
        fi
      done < "$TEND_REGISTRY"
      # Substring match
      while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        bname=$(basename "$path")
        if [[ "$bname" == *"$name"* && -d "$path" ]]; then
          echo "$path"
          return
        fi
      done < "$TEND_REGISTRY"
    fi

    # Fallback: try TEND_ROOT direct match
    if [[ -d "$TEND_ROOT/$name/.git" ]]; then
      echo "$TEND_ROOT/$name"
      return
    fi

    echo >&2 "tend: project '$name' not found"
    return 1
  fi

  # Auto-detect from $PWD (canonicalize to avoid case mismatches on macOS)
  local cur
  cur=$(pwd -P)
  while [[ "$cur" != "/" ]]; do
    if [[ -d "$cur/.git" ]]; then
      echo "$cur"
      return
    fi
    # Worktree: .git is a file containing "gitdir: <path>"
    if [[ -f "$cur/.git" ]]; then
      local gitdir
      gitdir=$(sed -n 's/^gitdir: //p' "$cur/.git")
      if [[ -n "$gitdir" ]]; then
        # Resolve to absolute path if relative
        [[ "$gitdir" != /* ]] && gitdir="$cur/$gitdir"
        # Follow worktree gitdir back to main repo:
        # e.g. /repo/.git/worktrees/name → /repo
        if [[ "$gitdir" == */.git/worktrees/* ]]; then
          local main_repo="${gitdir%%/.git/worktrees/*}"
          if [[ -d "$main_repo/.git" ]]; then
            echo "$main_repo"
            return
          fi
        fi
      fi
    fi
    cur="$(dirname "$cur")"
  done
  echo >&2 "tend: not inside a project (no .git found)"
  return 1
}

# Resolve project name (basename) from path or arg
_tend_resolve_project_name() {
  local path
  path=$(_tend_resolve_project_path "${1:-}") || return 1
  basename "$path"
}

# Parse the last event line from a project's .tend/events
# Sets globals: TEND_EVT_TS, TEND_EVT_STATE, TEND_EVT_MSG
_tend_last_event() {
  local project_path="$1"
  local events_file="$project_path/.tend/events"

  TEND_EVT_TS="" TEND_EVT_STATE="" TEND_EVT_MSG=""

  if [[ ! -f "$events_file" ]]; then
    return 1
  fi

  local last_line
  last_line=$(tail -1 "$events_file" 2>/dev/null) || return 1
  [[ -z "$last_line" ]] && return 1

  TEND_EVT_TS="${last_line%% *}"
  local rest="${last_line#* }"
  TEND_EVT_STATE="${rest%% *}"
  TEND_EVT_MSG="${rest#* }"
  # If state == msg, there was no message beyond the state
  [[ "$TEND_EVT_STATE" == "$TEND_EVT_MSG" ]] && TEND_EVT_MSG=""
  return 0
}

# Staleness threshold in seconds (default: 30 minutes)
TEND_STALE_THRESHOLD="${TEND_STALE_THRESHOLD:-1800}"

# Check if a timestamp is stale (older than threshold)
_tend_is_stale() {
  local ts="$1"
  local ts_epoch now_epoch delta
  ts_epoch=$(_tend_to_epoch "$ts")
  now_epoch=$(date "+%s")
  delta=$(( now_epoch - ts_epoch ))
  (( delta > TEND_STALE_THRESHOLD ))
}

# ─── Relay Helpers ───────────────────────────────────────────────────────────

TEND_RELAY_URL="${TEND_RELAY_URL:-https://relay.tend.cx}"
TEND_RELAY_TOKEN_FILE="${HOME}/.tend/relay_token"
TEND_RELAY_CACHE_DIR="${HOME}/.tend/relay_cache"

# Read the relay token from file or env
_tend_relay_token() {
  if [[ -n "${TEND_RELAY_TOKEN:-}" ]]; then
    echo "$TEND_RELAY_TOKEN"
    return
  fi
  if [[ -f "$TEND_RELAY_TOKEN_FILE" ]]; then
    cat "$TEND_RELAY_TOKEN_FILE"
    return
  fi
  return 1
}

# POST an event to the relay
_tend_relay_emit() {
  local project="$1" state="$2" message="${3:-}" session_id="${4:-}"
  local token
  token="${TEND_RELAY_TOKEN:-}"
  [[ -z "$token" ]] && return 1

  local ts
  ts=$(_tend_ts_local)

  local json="{\"project\":\"$project\",\"state\":\"$state\",\"message\":\"$message\",\"timestamp\":\"$ts\""
  if [[ -n "$session_id" ]]; then
    json+=",\"session_id\":\"$session_id\""
  fi
  json+="}"

  curl -s -f --connect-timeout 3 --max-time 10 -X POST "${TEND_RELAY_URL}/v1/events" \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -d "$json" >/dev/null 2>&1
}

# Fetch relay projects list and cache events locally
_tend_relay_sync() {
  local token
  token=$(_tend_relay_token 2>/dev/null) || return 0

  mkdir -p "$TEND_RELAY_CACHE_DIR"

  # Fetch project list
  local projects_json
  projects_json=$(curl -s -f --connect-timeout 3 --max-time 10 -X GET "${TEND_RELAY_URL}/v1/projects" \
    -H "Authorization: Bearer $token" 2>/dev/null) || return 0

  # Parse project names and fetch events for each
  local project_list
  project_list=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for p in data.get('projects', []):
    print(p)
" <<< "$projects_json" 2>/dev/null) || return 0

  while IFS= read -r project; do
    [[ -z "$project" ]] && continue
    _tend_relay_fetch_project "$project" "$token"
  done <<< "$project_list"
}

# Fetch events for one relay project and write to cache
_tend_relay_fetch_project() {
  local project="$1" token="$2"
  local cache_file="$TEND_RELAY_CACHE_DIR/$project"

  # Get since timestamp from last cached event
  local since_param=""
  if [[ -f "$cache_file" ]]; then
    local last_ts
    last_ts=$(tail -1 "$cache_file" 2>/dev/null | cut -d' ' -f1)
    [[ -n "$last_ts" ]] && since_param="?since=$last_ts"
  fi

  local events_json
  events_json=$(curl -s -f --connect-timeout 3 --max-time 10 -X GET "${TEND_RELAY_URL}/v1/events/${project}${since_param}" \
    -H "Authorization: Bearer $token" 2>/dev/null) || return 0

  # Convert JSON events to tend event format and append to cache
  python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
for e in data.get('events', []):
    ts = e.get('timestamp', '')
    sid = e.get('session_id', '')
    state = e.get('state', '')
    msg = e.get('message', '')
    if sid:
        print(f'{ts} {sid} {state} {msg}'.rstrip())
    else:
        print(f'{ts} {state} {msg}'.rstrip())
" <<< "$events_json" >> "$cache_file" 2>/dev/null || true
}

# List relay-only projects (on relay but not in local registry)
_tend_relay_projects() {
  [[ ! -d "$TEND_RELAY_CACHE_DIR" ]] && return
  local local_projects
  local_projects=$(_tend_discover_projects 2>/dev/null) || true

  for cache_file in "$TEND_RELAY_CACHE_DIR"/*; do
    [[ -f "$cache_file" ]] || continue
    local relay_project
    relay_project=$(basename "$cache_file")
    # Check if any local project has this basename
    local found=false
    while IFS= read -r lp; do
      [[ -z "$lp" ]] && continue
      if [[ "$(basename "$lp")" == "$relay_project" ]]; then
        found=true
        break
      fi
    done <<< "$local_projects"
    if ! $found; then
      echo "$relay_project"
    fi
  done
}

# Get aggregate state for a relay-only project from cache
_tend_relay_project_state() {
  local project_name="$1"
  local cache_file="$TEND_RELAY_CACHE_DIR/$project_name"

  TEND_AGG_STATE="" TEND_AGG_MSG="" TEND_AGG_TS="" TEND_AGG_ACTIVE=0

  if [[ ! -f "$cache_file" ]] || [[ ! -s "$cache_file" ]]; then
    return 1
  fi

  # Reuse the same awk aggregation as _tend_project_state
  local now_epoch
  now_epoch=$(date +%s)

  local result
  result=$(awk -v now="$now_epoch" -v stale_thresh="$TEND_STALE_THRESHOLD" '
    function is_state(s) {
      return (s == "working" || s == "done" || s == "stuck" || s == "waiting" || s == "idle")
    }
    function priority(s) {
      if (s == "stuck") return 5
      if (s == "done") return 4
      if (s == "waiting") return 3
      if (s == "working") return 2
      return 0
    }
    function to_epoch(ts,    cmd, ep) {
      cmd = "date -j -f \"%Y-%m-%dT%H:%M:%S\" \"" ts "\" +%s 2>/dev/null || date -d \"" ts "\" +%s 2>/dev/null"
      cmd | getline ep
      close(cmd)
      return ep + 0
    }
    {
      ts = $1
      if ($2 == "*") {
        for (k in sess) delete sess[k]
        for (k in sess_ts) delete sess_ts[k]
        for (k in sess_msg) delete sess_msg[k]
        sess["_"] = $3
        sess_ts["_"] = ts
        sess_msg["_"] = ""
      } else if (is_state($2)) {
        sess["_cli"] = $2
        sess_ts["_cli"] = ts
        msg = ""
        for (i = 3; i <= NF; i++) msg = (msg ? msg " " $i : $i)
        sess_msg["_cli"] = msg
      } else if (is_state($3)) {
        sess[$2] = $3
        sess_ts[$2] = ts
        msg = ""
        for (i = 4; i <= NF; i++) msg = (msg ? msg " " $i : $i)
        sess_msg[$2] = msg
      }
      last_ts = ts
    }
    END {
      if (length(sess) == 0) exit 1
      for (s in sess) {
        if (sess[s] == "working") {
          ep = to_epoch(sess_ts[s])
          if (ep > 0 && (now - ep) > stale_thresh) {
            sess[s] = "idle"
          }
        }
      }
      best = "idle"; best_p = 0; best_msg = ""; active = 0
      working_ts = ""
      for (s in sess) {
        p = priority(sess[s])
        if (sess[s] != "idle") active++
        if (sess[s] == "working") {
          working_ts = (working_ts ? working_ts "," : "") sess_ts[s]
        }
        if (p > best_p) {
          best_p = p
          best = sess[s]
          best_msg = sess_msg[s]
        }
      }
      printf "%s\t%s\t%s\t%d\t%s\n", last_ts, best, best_msg, active, working_ts
    }
  ' "$cache_file")

  if [[ -z "$result" ]]; then
    return 1
  fi

  TEND_AGG_TS=$(printf '%s' "$result" | cut -f1)
  TEND_AGG_STATE=$(printf '%s' "$result" | cut -f2)
  TEND_AGG_MSG=$(printf '%s' "$result" | cut -f3)
  TEND_AGG_ACTIVE=$(printf '%s' "$result" | cut -f4)

  return 0
}

# Check if a state is a "needs attention" state
_tend_needs_attention() {
  local state="$1"
  [[ "$state" == "done" || "$state" == "stuck" || "$state" == "waiting" ]]
}

# Compute aggregate project state from events (supports multi-session)
# Sets: TEND_AGG_STATE, TEND_AGG_MSG, TEND_AGG_TS, TEND_AGG_ACTIVE
_tend_project_state() {
  local project_path="$1"
  local events_file="$project_path/.tend/events"

  TEND_AGG_STATE="" TEND_AGG_MSG="" TEND_AGG_TS="" TEND_AGG_ACTIVE=0

  # Check for relay cache for this project (merge local + relay)
  local project_name
  project_name=$(basename "$project_path")
  local relay_cache="$TEND_RELAY_CACHE_DIR/$project_name"

  local has_local=false has_relay=false
  [[ -f "$events_file" ]] && [[ -s "$events_file" ]] && has_local=true
  [[ -f "$relay_cache" ]] && [[ -s "$relay_cache" ]] && has_relay=true

  if ! $has_local && ! $has_relay; then
    return 1
  fi

  # Build input: merge local + relay events, sorted by timestamp
  local merged_input
  if $has_local && $has_relay; then
    merged_input=$(sort -t' ' -k1,1 "$events_file" "$relay_cache")
  elif $has_local; then
    merged_input=$(cat "$events_file")
  else
    merged_input=$(cat "$relay_cache")
  fi

  local now_epoch
  now_epoch=$(date +%s)

  local result
  result=$(awk -v now="$now_epoch" -v stale_thresh="$TEND_STALE_THRESHOLD" '
    function is_state(s) {
      return (s == "working" || s == "done" || s == "stuck" || s == "waiting" || s == "idle")
    }
    function priority(s) {
      if (s == "stuck") return 5
      if (s == "waiting") return 4
      if (s == "working") return 3
      if (s == "done") return 2
      return 0
    }
    function to_epoch(ts,    cmd, ep) {
      # Convert ISO timestamp to epoch using date command
      cmd = "date -j -f \"%Y-%m-%dT%H:%M:%S\" \"" ts "\" +%s 2>/dev/null || date -d \"" ts "\" +%s 2>/dev/null"
      cmd | getline ep
      close(cmd)
      return ep + 0
    }
    {
      ts = $1
      if ($2 == "*") {
        # Reset marker (from tend ack)
        for (k in sess) delete sess[k]
        for (k in sess_ts) delete sess_ts[k]
        for (k in sess_msg) delete sess_msg[k]
        sess["_"] = $3
        sess_ts["_"] = ts
        sess_msg["_"] = ""
      } else if (is_state($2)) {
        # Old format (no session ID) — treat as _cli session
        sess["_cli"] = $2
        sess_ts["_cli"] = ts
        msg = ""
        for (i = 3; i <= NF; i++) msg = (msg ? msg " " $i : $i)
        sess_msg["_cli"] = msg
      } else if (is_state($3)) {
        # New format: $2 is session ID
        sess[$2] = $3
        sess_ts[$2] = ts
        msg = ""
        for (i = 4; i <= NF; i++) msg = (msg ? msg " " $i : $i)
        sess_msg[$2] = msg
      }
      last_ts = ts
    }
    END {
      if (length(sess) == 0) exit 1
      # Demote stale working sessions to idle before aggregating
      for (s in sess) {
        if (sess[s] == "working") {
          ep = to_epoch(sess_ts[s])
          if (ep > 0 && (now - ep) > stale_thresh) {
            sess[s] = "idle"
          }
        }
      }
      best = "idle"; best_p = 0; best_msg = ""; active = 0
      working_ts = ""
      for (s in sess) {
        p = priority(sess[s])
        if (sess[s] != "idle") active++
        if (sess[s] == "working") {
          working_ts = (working_ts ? working_ts "," : "") sess_ts[s]
        }
        if (p > best_p) {
          best_p = p
          best = sess[s]
          best_msg = sess_msg[s]
        }
      }
      printf "%s\t%s\t%s\t%d\t%s\n", last_ts, best, best_msg, active, working_ts
    }
  ' <<< "$merged_input")

  if [[ -z "$result" ]]; then
    return 1
  fi

  TEND_AGG_TS=$(printf '%s' "$result" | cut -f1)
  TEND_AGG_STATE=$(printf '%s' "$result" | cut -f2)
  TEND_AGG_MSG=$(printf '%s' "$result" | cut -f3)
  TEND_AGG_ACTIVE=$(printf '%s' "$result" | cut -f4)

  return 0
}

# Icon for a given state
_tend_state_icon() {
  local state="$1"
  case "$state" in
    stuck)        echo "▲" ;;
    waiting)      echo "▲" ;;
    done)         echo "◆" ;;
    working)      echo "◉" ;;
    unknown)      echo "◌" ;;
    idle|"")      echo "◌" ;;
    *)            echo "◌" ;;
  esac
}

# Color for a given state
_tend_state_color() {
  local state="$1"
  case "$state" in
    stuck)        echo "$C_RED" ;;
    waiting)      echo "$C_RED" ;;
    done)         echo "$C_GREEN" ;;
    working)      echo "$C_CYAN" ;;
    unknown)      echo "$C_GREY" ;;
    idle|"")      echo "$C_GREY" ;;
    *)            echo "$C_GREY" ;;
  esac
}

# State label for display
_tend_state_label() {
  local state="$1"
  case "$state" in
    done)    echo "done" ;;
    stuck)   echo "stuck" ;;
    waiting) echo "waiting" ;;
    working) echo "working" ;;
    unknown) echo "unknown" ;;
    idle)    echo "idle" ;;
    *)       echo "no signal" ;;
  esac
}

# ─── Gamification ────────────────────────────────────────────────────────────

# Returns 0 (true) when gamification display is enabled.
# Disable by setting TEND_NO_GAMIFICATION=1.
_tend_gamification_enabled() {
  [[ -z "${TEND_NO_GAMIFICATION:-}" ]]
}

# Determine overall kitchen heat from current board counters.
# Args: working_count needs_count stuck_count oldest_wait_age_secs ready_count
# Echoes: fire|hot|warming|simmering|ready|cold
_tend_kitchen_heat() {
  local working="$1" needs="$2" stuck="$3" wait_age="${4:-0}" ready="${5:-0}"
  # needs is already stuck+waiting only (done excluded)
  if   (( needs > 0 && wait_age > 900 )); then echo "fire"
  elif (( needs > 0 && wait_age > 300 )); then echo "hot"
  elif (( needs > 0 ));                   then echo "warming"
  elif (( working > 0 ));                 then echo "simmering"
  elif (( ready > 0 ));                   then echo "ready"
  else echo "cold"
  fi
}

# Render the single pot-status line.
# Args: heat_state working_count hot_count (stuck+waiting, excludes done)
_tend_pot_line() {
  local heat="${1:-cold}" working="${2:-0}" hot="${3:-0}"
  local icon desc color
  case "$heat" in
    fire)
      icon="▲"; color="${C_BOLD}${C_RED}"
      if (( hot == 1 )); then desc="1 waiting — overdue, check now"
      else                    desc="${hot} waiting — overdue, check now"; fi ;;
    hot)
      icon="▲"; color="$C_AMBER"
      if (( hot == 1 )); then desc="1 waiting — needs attention"
      else                    desc="${hot} waiting — need attention"; fi ;;
    warming)
      icon="△"; color="$C_AMBER"
      if (( hot == 1 )); then desc="1 waiting"
      else                    desc="${hot} waiting"; fi ;;
    simmering)
      icon="◉"; color="$C_CYAN"
      if (( working == 1 )); then desc="1 working"
      else                        desc="${working} working"; fi ;;
    ready)
      icon="◆"; color="$C_GREEN"
      desc="done — review results" ;;
    cold|*)
      icon="◌"; color="$C_GREY"
      desc="idle" ;;
  esac
  printf "  %s%s  %s%s\n" "$color" "$icon" "$desc" "$C_RESET"
}

# Compute gamification stats from all registered project events files.
# Sets globals: TEND_STATS_DONES_TODAY TEND_STATS_DONES_WEEK
#               TEND_STATS_PEAK_TODAY  TEND_STATS_PEAK_WEEK
#               TEND_STATS_STREAK      TEND_STATS_TODOS_OPEN
_tend_gamification_stats() {
  TEND_STATS_DONES_TODAY=0
  TEND_STATS_DONES_WEEK=0
  TEND_STATS_PEAK_TODAY=0
  TEND_STATS_PEAK_WEEK=0
  TEND_STATS_STREAK=0
  TEND_STATS_TODOS_OPEN=0

  local today
  today=$(date +%Y-%m-%d)

  # Portable week start (Monday of current ISO week)
  local dow days_back week_start
  dow=$(date +%u 2>/dev/null || echo 1)
  days_back=$(( dow - 1 ))
  if (( days_back == 0 )); then
    week_start="$today"
  else
    week_start=$(date -v-${days_back}d +%Y-%m-%d 2>/dev/null || \
                 date -d "${days_back} days ago" +%Y-%m-%d 2>/dev/null || \
                 echo "$today")
  fi

  # Collect events files and count open TODOs across all projects
  local -a events_files=()
  local projects
  projects=$(_tend_discover_projects) || true

  while IFS= read -r project; do
    [[ -z "$project" ]] && continue
    local ef="$project/.tend/events"
    [[ -f "$ef" ]] && [[ -s "$ef" ]] && events_files+=("$ef")
    local tf="$project/.tend/TODO"
    if [[ -f "$tf" ]] && [[ -s "$tf" ]]; then
      local cnt
      cnt=$(grep -c . "$tf" 2>/dev/null) || cnt=0
      TEND_STATS_TODOS_OPEN=$(( TEND_STATS_TODOS_OPEN + cnt ))
    fi
  done <<< "$projects"

  [[ ${#events_files[@]} -eq 0 ]] && return

  # Parse events with awk: count dones/working sessions by date
  local raw
  raw=$(awk -v today="$today" -v week_start="$week_start" '
    function is_state(s) {
      return (s=="working"||s=="done"||s=="stuck"||s=="waiting"||s=="idle")
    }
    {
      ts_date = substr($1, 1, 10)
      if ($2 == "*") next
      if      (is_state($2)) { state=$2; sess="_cli" }
      else if (is_state($3)) { sess=$2; state=$3 }
      else next
      if (state == "done") {
        if (ts_date == today)      today_dones++
        if (ts_date >= week_start) week_dones++
        done_days[ts_date] = 1
      }
      if (state == "working") {
        if (ts_date == today)      today_sess[sess] = 1
        if (ts_date >= week_start) week_sess[sess]  = 1
      }
    }
    END {
      printf "dones_today=%d\n", today_dones+0
      printf "dones_week=%d\n",  week_dones+0
      printf "peak_today=%d\n",  length(today_sess)
      printf "peak_week=%d\n",   length(week_sess)
      for (d in done_days) printf "done_day=%s\n", d
    }
  ' "${events_files[@]}")

  # Parse key=value output
  local done_days_list=""
  while IFS='=' read -r key val; do
    case "$key" in
      dones_today) TEND_STATS_DONES_TODAY="$val" ;;
      dones_week)  TEND_STATS_DONES_WEEK="$val"  ;;
      peak_today)  TEND_STATS_PEAK_TODAY="$val"  ;;
      peak_week)   TEND_STATS_PEAK_WEEK="$val"   ;;
      done_day)    done_days_list="${done_days_list}${val}"$'\n' ;;
    esac
  done <<< "$raw"

  # Compute streak: consecutive days ending today with at least one done
  [[ -z "$done_days_list" ]] && return

  local sorted_days
  sorted_days=$(printf '%s' "$done_days_list" | sort -r | uniq)

  local today_epoch d_epoch expected streak=0
  today_epoch=$(_tend_to_epoch "${today}T00:00:00")
  expected=$today_epoch

  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    d_epoch=$(_tend_to_epoch "${d}T00:00:00")
    if (( d_epoch == expected )); then
      (( ++streak ))
      expected=$(( expected - 86400 ))
    else
      break
    fi
  done <<< "$sorted_days"

  TEND_STATS_STREAK=$streak
}

# Render the gamification stats footer (separator + tally lines).
_tend_gamification_footer() {
  _tend_gamification_stats

  # Today line
  local today_str="${TEND_STATS_DONES_TODAY} done today"
  if (( TEND_STATS_PEAK_TODAY == 1 )); then
    today_str+="  ·  peak 1 agent"
  elif (( TEND_STATS_PEAK_TODAY > 1 )); then
    today_str+="  ·  peak ${TEND_STATS_PEAK_TODAY} agents"
  fi

  # Streak indicator
  local streak_str=""
  if (( TEND_STATS_STREAK >= 7 )); then
    streak_str="  ·  ${C_AMBER}▲${C_RESET}${C_DIM} ${TEND_STATS_STREAK}-day streak"
  elif (( TEND_STATS_STREAK > 0 )); then
    streak_str="  ·  ◆ ${TEND_STATS_STREAK}-day streak"
  fi

  # Week line (only when it adds information beyond today)
  local week_str=""
  if (( TEND_STATS_DONES_WEEK > TEND_STATS_DONES_TODAY )); then
    week_str="${TEND_STATS_DONES_WEEK} done this week"
    if (( TEND_STATS_PEAK_WEEK == 1 )); then
      week_str+="  ·  peak 1 agent"
    elif (( TEND_STATS_PEAK_WEEK > 1 )); then
      week_str+="  ·  peak ${TEND_STATS_PEAK_WEEK} agents"
    fi
  fi

  # Open TODOs line
  local todo_str=""
  if (( TEND_STATS_TODOS_OPEN == 1 )); then
    todo_str="1 open TODO"
  elif (( TEND_STATS_TODOS_OPEN > 1 )); then
    todo_str="${TEND_STATS_TODOS_OPEN} open TODOs"
  fi

  printf "  %s──────────────────────────────────────────────────%s\n" "$C_DIM" "$C_RESET"
  printf "  %s%s%s%s\n" "$C_DIM" "$today_str" "$streak_str" "$C_RESET"
  if [[ -n "$week_str" ]]; then
    printf "  %s%s%s\n" "$C_DIM" "$week_str" "$C_RESET"
  fi
  if [[ -n "$todo_str" ]]; then
    printf "  %s%s%s\n" "$C_DIM" "$todo_str" "$C_RESET"
  fi
}

# ─── Commands ────────────────────────────────────────────────────────────────

# --- tend init ---
_tend_cmd_init() {
  local project_path
  project_path=$(_tend_resolve_project_path "${1:-}") || exit 1
  local project_name
  project_name=$(basename "$project_path")

  local tend_dir="$project_path/.tend"
  mkdir -p "$tend_dir"

  local file
  for file in events TODO; do
    if [[ ! -f "$tend_dir/$file" ]]; then
      touch "$tend_dir/$file"
    fi
  done

  # Gitignore machine-local tend artifacts
  local gitignore="$project_path/.gitignore"
  local entry
  for entry in ".tend/events" ".tend/hook_debug.log" ".github/hooks/" ".scratch/"; do
    if [[ ! -f "$gitignore" ]] || ! grep -qxF "$entry" "$gitignore" 2>/dev/null; then
      echo "$entry" >> "$gitignore"
    fi
  done

  # Add tend integration to AGENTS.md
  local agents_file="$project_path/AGENTS.md"
  local tend_marker="## Tend Integration"

  if [[ ! -f "$agents_file" ]]; then
    _tend_write_agents_block "$agents_file"
    echo "✓ Created AGENTS.md with tend integration in $project_name"
  elif ! grep -q "$tend_marker" "$agents_file" 2>/dev/null; then
    echo "" >> "$agents_file"
    _tend_write_agents_block_content >> "$agents_file"
    echo "✓ Added tend integration to AGENTS.md in $project_name"
  elif ! grep -q 'session-id' "$agents_file" 2>/dev/null; then
    # Outdated tend block — replace it
    _tend_replace_agents_block "$agents_file"
    echo "✓ Updated tend integration in AGENTS.md in $project_name"
  else
    echo "✓ AGENTS.md already has tend integration in $project_name"
  fi

  # Register project in tend registry
  _tend_register_project "$project_path"

  # Add shell prompt integration
  _tend_setup_shell

  # Create VS Code hooks config
  local hooks_dir="$project_path/.github/hooks"
  local hooks_file="$hooks_dir/tend.json"
  if [[ ! -f "$hooks_file" ]]; then
    mkdir -p "$hooks_dir"
    cat > "$hooks_file" <<'HOOKS_EOF'
{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "tend hook session-start"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "tend hook user-prompt"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "tend hook stop"
      }
    ]
  }
}
HOOKS_EOF
    echo "✓ Created .github/hooks/tend.json"
  fi

  echo "✓ Initialized .tend/ in $project_name"
}

# Add tend status indicator to shell rc files
_tend_setup_shell() {
  local tend_shell_marker="# --- Tend status indicator ---"
  local did_setup=false

  # zsh
  if [[ -f "$HOME/.zshrc" ]]; then
    if ! grep -q "$tend_shell_marker" "$HOME/.zshrc" 2>/dev/null; then
      cat >> "$HOME/.zshrc" <<'SHELL_EOF'

# --- Tend status indicator ---
setopt PROMPT_SUBST
_tend_precmd() { _TEND_S="$(tend status 2>/dev/null)"; }
precmd_functions+=(_tend_precmd)
RPROMPT='$_TEND_S'
SHELL_EOF
      did_setup=true
      echo "✓ Added tend status to ~/.zshrc (shows in right prompt)"
    fi
  fi

  # bash
  for rcfile in "$HOME/.bashrc" "$HOME/.bash_profile"; do
    if [[ -f "$rcfile" ]]; then
      if ! grep -q "$tend_shell_marker" "$rcfile" 2>/dev/null; then
        cat >> "$rcfile" <<'SHELL_EOF'

# --- Tend status indicator ---
_tend_prompt() { _TEND_S="$(tend status 2>/dev/null)"; PS1="${PS1%\\$ *}$_TEND_S \$ "; }
PROMPT_COMMAND="_tend_prompt${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
SHELL_EOF
        did_setup=true
        echo "✓ Added tend status to ~/${rcfile##*/}"
      fi
    fi
  done

  if $did_setup; then
    echo "  Restart your shell or run: source ~/.zshrc"
  fi
}

# Write the full AGENTS.md file (for new files)
_tend_write_agents_block() {
  local file="$1"
  _tend_write_agents_block_content > "$file"
}

# Replace an outdated tend block in AGENTS.md
_tend_replace_agents_block() {
  local file="$1"
  local tmp="${file}.tmp.$$"
  local in_tend_block=false
  local found=false
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "## Tend Integration"* ]]; then
      in_tend_block=true
      found=true
      _tend_write_agents_block_content >> "$tmp"
      continue
    fi
    if $in_tend_block; then
      # Next ## heading ends the tend block
      if [[ "$line" == "## "* ]]; then
        in_tend_block=false
        printf '%s\n' "$line" >> "$tmp"
      fi
      # Skip old tend block lines
      continue
    fi
    printf '%s\n' "$line" >> "$tmp"
  done < "$file"
  if $found; then
    mv "$tmp" "$file"
  else
    rm -f "$tmp"
  fi
}

# Output the tend integration block
_tend_write_agents_block_content() {
  cat <<'AGENTS_EOF'
## Tend Integration

This project uses [Tend](https://github.com/tend-cli/tend) for workflow coordination.

### Setup

If `tend` is not on PATH, install it:

```bash
curl -sSL https://raw.githubusercontent.com/metalaureate/tend-cli/main/bin/tend -o /usr/local/bin/tend && chmod +x /usr/local/bin/tend
```

### On Startup

1. Read `.tend/TODO` — propose pending items to the developer and ask what to work on.
2. Review recent git history for context on what's already been done.
3. Emit: `tend emit working "<description of what you're starting>"`

### During Work

- When you complete a task: `tend emit done "<summary>"`
- When you start a new task: `tend emit working "<description>"`
- When you need human input: `tend emit stuck "<what you need>"`
- When you complete a task, also append to `.tend/DONE` with a timestamp.

### On Completion

- Emit: `tend emit idle`
- If there are items in `.tend/TODO`, note the next item but wait for the developer to assign it (do not auto-start).

### Event Format

If `tend` is not available, append a single line to `.tend/events`:

```
<ISO-8601-timestamp> <session-id> <state> <message>
```

Use `$TEND_SESSION_ID` as the session ID if set, otherwise use `_cli`.

States: `working`, `done`, `stuck`, `waiting`, `idle`.

Example:
```
2026-03-13T14:20:00 _cli working refactoring narrative engine
2026-03-13T14:45:00 _cli done refactored narrative engine (PR #204)
2026-03-13T14:46:00 _cli stuck tool approval needed: npm test
```

AGENTS_EOF
}

# --- tend clear ---
_tend_cmd_clear() {
  local project_path
  project_path=$(_tend_resolve_project_path "${1:-}") || exit 1
  local project_name
  project_name=$(basename "$project_path")
  local events_file="$project_path/.tend/events"

  if [[ ! -f "$events_file" ]]; then
    echo "No events to clear for $project_name"
    return 0
  fi

  > "$events_file"
  echo "✓ Cleared events for $project_name"
}

# --- tend emit ---
_tend_cmd_emit() {
  local state="${1:-}"
  shift || true
  local message="$*"

  if [[ -z "$state" ]]; then
    echo >&2 "Usage: tend emit <state> [message]"
    echo >&2 "States: working, done, stuck, waiting, idle"
    exit 1
  fi

  case "$state" in
    working|done|stuck|waiting|idle) ;;
    *)
      echo >&2 "tend: invalid state '$state'"
      echo >&2 "Valid states: working, done, stuck, waiting, idle"
      exit 1
      ;;
  esac

  # Relay mode: POST to relay when TEND_RELAY_TOKEN is set
  if [[ -n "${TEND_RELAY_TOKEN:-}" ]]; then
    local project_name
    project_name=$(_tend_resolve_project_name "" 2>/dev/null) || project_name="${PWD##*/}"
    local session_id="${TEND_SESSION_ID:-}"
    if _tend_relay_emit "$project_name" "$state" "$message" "$session_id"; then
      return 0
    fi
    echo >&2 "tend: relay unreachable, falling back to local"
    # Fall through to local write if .tend/ exists
  fi

  local project_path
  project_path=$(_tend_resolve_project_path "") || exit 1

  local events_file="$project_path/.tend/events"
  if [[ ! -d "$project_path/.tend" ]]; then
    echo >&2 "tend: .tend/ not initialized. Run 'tend init' first."
    exit 1
  fi

  local ts
  ts=$(_tend_ts_local)
  local session_id="${TEND_SESSION_ID:-_cli}"
  echo "$ts $session_id $state $message" >> "$events_file"
}

# --- tend status ---
_tend_cmd_status() {
  local hot=0 working=0 done_count=0
  local projects
  projects=$(_tend_discover_projects) || true

  local project
  while IFS= read -r project; do
    [[ -z "$project" ]] && continue
    if _tend_project_state "$project"; then
      case "$TEND_AGG_STATE" in
        stuck|waiting) (( ++hot )) ;;
        working) (( working += TEND_AGG_ACTIVE > 0 ? TEND_AGG_ACTIVE : 1 )) ;;
        done)    (( ++done_count )) ;;
      esac
    fi
  done <<< "$projects"

  # Also count relay-only projects (from cache, no network)
  local relay_project
  while IFS= read -r relay_project; do
    [[ -z "$relay_project" ]] && continue
    if _tend_relay_project_state "$relay_project"; then
      case "$TEND_AGG_STATE" in
        stuck|waiting) (( ++hot )) ;;
        working) (( working += TEND_AGG_ACTIVE > 0 ? TEND_AGG_ACTIVE : 1 )) ;;
        done)    (( ++done_count )) ;;
      esac
    fi
  done <<< "$(_tend_relay_projects 2>/dev/null)"

  # Build compact per-state indicator: ▲ stuck/waiting, ◉ working, ◆ done
  # Use inline ANSI when parent shell is interactive (prompt use via $(...))
  local _r="" _red="" _cyan="" _green=""
  if [[ -z "${NO_COLOR:-}" ]] && [[ -t 2 || -n "${TEND_FORCE_COLOR:-}" ]]; then
    _r=$'\033[0m' _red=$'\033[31m' _cyan=$'\033[36m' _green=$'\033[32m'
  fi
  local parts=()
  (( hot > 0 ))       && parts+=("${_red}▲${hot}${_r}")
  (( working > 0 ))   && parts+=("${_cyan}◉${working}${_r}")
  (( done_count > 0 )) && parts+=("${_green}◆${done_count}${_r}")
  if (( ${#parts[@]} == 0 )); then
    echo "○"
  else
    local IFS=" "
    echo "${parts[*]}"
  fi
}

# --- tend (board) ---
_tend_cmd_board() {
  # Start spinner on the command line (same line user typed "tend")
  local _spin_pid=""
  if [[ -t 1 ]]; then
    (
      trap 'exit 0' TERM
      local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
      local i=0
      while true; do
        printf " %s\b\b" "${frames[i++ % ${#frames[@]}]}" >&2
        sleep 0.08
      done
    ) &
    _spin_pid=$!
    disown "$_spin_pid" 2>/dev/null
  fi

  # Refresh relay cache (network call, before rendering)
  _tend_relay_sync 2>/dev/null || true

  local projects
  projects=$(_tend_discover_projects) || true

  # Check for relay-only projects too
  local relay_only
  relay_only=$(_tend_relay_projects 2>/dev/null) || true
  local has_local_projects=true
  if [[ -z "$projects" ]]; then
    has_local_projects=false
  fi
  if [[ -z "$projects" && -z "$relay_only" ]]; then
    # Stop spinner before early exit
    if [[ -n "$_spin_pid" ]]; then
      kill "$_spin_pid" 2>/dev/null; wait "$_spin_pid" 2>/dev/null
      printf "\r\033[K" >&2
    fi
    echo "  No tended projects found"
    echo "  Run 'tend init' inside a project to start tending it"
    return
  fi

  # Detect current project (from $PWD)
  local current_project_path=""
  local cur
  cur=$(pwd -P 2>/dev/null) || true
  while [[ "$cur" != "/" ]]; do
    if [[ -d "$cur/.git" ]]; then
      current_project_path="$cur"
      break
    fi
    cur="$(dirname "$cur")"
  done

  # Sort projects by last event time (most recent first), current project pinned to top
  projects=$(_tend_sorted_projects)

  # Stop spinner, clear the command line
  if [[ -n "$_spin_pid" ]]; then
    kill "$_spin_pid" 2>/dev/null; wait "$_spin_pid" 2>/dev/null
    printf "\r\033[K" >&2
  fi

  # Header
  echo ""
  echo "  ${C_BOLD}TEND${C_RESET}                               $(_tend_date_header)"
  echo ""

  local needs=0 ready=0 working_count=0 idle_count=0 stuck_count=0
  local oldest_waiting_age=0
  local project
  local -a switch_paths=()
  local project_num=0

  while IFS= read -r project; do
    [[ -z "$project" ]] && continue
    local project_path="$project"
    local project_name
    project_name=$(basename "$project_path")
    (( ++project_num ))
    switch_paths+=( "$project_path" )

    local state="" msg="" ts="" duration_str="" active_count=0

    if _tend_project_state "$project_path"; then
      state="$TEND_AGG_STATE"
      msg="$TEND_AGG_MSG"
      ts="$TEND_AGG_TS"
      active_count="$TEND_AGG_ACTIVE"

      # For idle with no message, check for uncommitted work before falling back to last commit
      if [[ "$state" == "idle" && -z "$msg" && -d "$project_path/.git" ]]; then
        local _dirty
        _dirty=$(git -C "$project_path" status --porcelain 2>/dev/null) || true
        if [[ -n "$_dirty" ]]; then
          msg="uncommitted changes"
        else
          msg=$(git -C "$project_path" log --oneline -1 --format="%s" 2>/dev/null) || true
        fi
      fi

      # Staleness already handled by _tend_project_state
      if [[ "$state" == "unknown" && -n "$ts" ]]; then
        local ago
        ago=$(_tend_ago "$ts")
        duration_str="${ago} ago"
        msg="was: ${msg}"
      elif [[ "$state" == "working" && -n "$ts" ]]; then
        local ago
        ago=$(_tend_ago "$ts")
        duration_str="${ago}"
      elif [[ "$state" == "idle" && -n "$ts" ]]; then
        local ago
        ago=$(_tend_ago "$ts")
        duration_str="${ago} ago"
      elif [[ "$state" == "done" && -n "$ts" ]]; then
        local ago
        ago=$(_tend_ago "$ts")
        duration_str="${ago} ago"
      fi
    else
      # No events — check for uncommitted work, then try git fallback
      if [[ -d "$project_path/.git" ]]; then
        local _dirty
        _dirty=$(git -C "$project_path" status --porcelain 2>/dev/null) || true
        if [[ -n "$_dirty" ]]; then
          state="idle"
          msg="uncommitted changes"
          duration_str=$(git -C "$project_path" log --oneline -1 --format="%ar" 2>/dev/null) || true
        else
          local last_commit_msg last_commit_ago
          last_commit_msg=$(git -C "$project_path" log --oneline -1 --format="%s" 2>/dev/null) || true
          last_commit_ago=$(git -C "$project_path" log --oneline -1 --format="%ar" 2>/dev/null) || true
          if [[ -n "$last_commit_msg" ]]; then
            state="idle"
            msg="$last_commit_msg"
            duration_str="$last_commit_ago"
          fi
        fi
      fi
    fi

    # Count states (use active_count for working to count sessions, not projects)
    case "$state" in
      done)    (( ++ready )) ;;
      stuck)   (( ++stuck_count )); (( ++needs )) ;;
      waiting) (( ++needs )) ;;
      working) (( working_count += active_count > 0 ? active_count : 1 )) ;;
      unknown) (( ++idle_count )) ;;
      idle|"") (( ++idle_count )) ;;
    esac

    # Track age of waiting/stuck agents for kitchen heat calculation
    if [[ ( "$state" == "waiting" || "$state" == "stuck" ) && -n "$ts" ]]; then
      local ts_e now_e age_s
      ts_e=$(_tend_to_epoch "$ts")
      now_e=$(date +%s)
      age_s=$(( now_e - ts_e ))
      (( age_s > oldest_waiting_age )) && oldest_waiting_age=$age_s
    fi

    # Render line
    local icon color label
    icon=$(_tend_state_icon "$state")
    color=$(_tend_state_color "$state")
    label=$(_tend_state_label "$state")
    if (( active_count > 1 )); then
      label="${active_count} ${state}"
    fi

    # Truncate project name to 20 chars, pad to 20
    local display_name
    display_name=$(printf "%-20.20s" "$project_name")

    # Build the detail string (msg) and time column (duration_str) separately
    local detail="$msg"

    # Truncate detail to fit terminal, leaving room for time column
    local term_width=${COLUMNS:-80}
    local time_col_width=0
    if [[ -n "$duration_str" ]]; then
      time_col_width=$(( ${#duration_str} + 3 ))  # 2 spaces + parens
    fi
    local prefix_width=47  # 2 indent + 3 num + 2 icon + 1 sp + 20 name + 2 sp + 15 label + 2 sp
    local max_detail=$(( term_width - prefix_width - time_col_width ))
    if (( max_detail < 10 )); then max_detail=10; fi
    if [[ -n "$detail" ]] && (( ${#detail} > max_detail )); then
      detail="${detail:0:$(( max_detail - 3 ))}..."
    fi

    local num_prefix
    num_prefix=$(printf "%2d." "$project_num")
    printf "  %s %s  %s%s %-15s%s" \
      "$num_prefix" "$display_name" "$color" "$icon" "$label" "$C_RESET"
    if [[ -n "$detail" ]]; then
      printf "%s" "$detail"
    fi
    if [[ -n "$duration_str" ]]; then
      printf "  ${C_GREY}(%s)${C_RESET}" "$duration_str"
    fi
    echo ""
  done <<< "$projects"

  # Render relay-only projects
  if [[ -n "$relay_only" ]]; then
    while IFS= read -r relay_project; do
      [[ -z "$relay_project" ]] && continue

      local state="" msg="" ts="" duration_str="" active_count=0

      if _tend_relay_project_state "$relay_project"; then
        state="$TEND_AGG_STATE"
        msg="$TEND_AGG_MSG"
        ts="$TEND_AGG_TS"
        active_count="$TEND_AGG_ACTIVE"

        if [[ "$state" == "unknown" && -n "$ts" ]]; then
          local ago; ago=$(_tend_ago "$ts")
          duration_str="${ago} ago"
          msg="was: ${msg}"
        elif [[ "$state" == "working" && -n "$ts" ]]; then
          local ago; ago=$(_tend_ago "$ts")
          duration_str="${ago}"
        elif [[ "$state" == "idle" && -n "$ts" ]]; then
          local ago; ago=$(_tend_ago "$ts")
          duration_str="${ago} ago"
        elif [[ "$state" == "done" && -n "$ts" ]]; then
          local ago; ago=$(_tend_ago "$ts")
          duration_str="${ago} ago"
        fi
      fi

      case "$state" in
        done)    (( ++ready )) ;;
        stuck)   (( ++stuck_count )); (( ++needs )) ;;
        waiting) (( ++needs )) ;;
        working) (( working_count += active_count > 0 ? active_count : 1 )) ;;
        idle|"") (( ++idle_count )) ;;
      esac

      # Track age of waiting/stuck relay agents for kitchen heat calculation
      if [[ ( "$state" == "waiting" || "$state" == "stuck" ) && -n "$ts" ]]; then
        local ts_e now_e age_s
        ts_e=$(_tend_to_epoch "$ts")
        now_e=$(date +%s)
        age_s=$(( now_e - ts_e ))
        (( age_s > oldest_waiting_age )) && oldest_waiting_age=$age_s
      fi

      local icon color label
      icon=$(_tend_state_icon "$state")
      color=$(_tend_state_color "$state")
      label=$(_tend_state_label "$state")
      if (( active_count > 1 )); then label="${active_count} ${state}"; fi

      local display_name
      display_name=$(printf "%-19.19s" "$relay_project")
      display_name="${display_name}↗"

      local detail="$msg"

      local term_width=${COLUMNS:-80}
      local time_col_width=0
      if [[ -n "$duration_str" ]]; then
        time_col_width=$(( ${#duration_str} + 3 ))
      fi
      local prefix_width=47
      local max_detail=$(( term_width - prefix_width - time_col_width ))
      if (( max_detail < 10 )); then max_detail=10; fi
      if [[ -n "$detail" ]] && (( ${#detail} > max_detail )); then detail="${detail:0:$(( max_detail - 3 ))}..."; fi

      printf "     %s  %s%s %-15s%s" \
        "$display_name" "$color" "$icon" "$label" "$C_RESET"
      if [[ -n "$detail" ]]; then
        printf "%s" "$detail"
      fi
      if [[ -n "$duration_str" ]]; then
        printf "  ${C_GREY}(%s)${C_RESET}" "$duration_str"
      fi
      echo ""
    done <<< "$relay_only"
  fi

  # Footer
  echo ""
  local footer_parts=()
  (( needs > 0 )) && footer_parts+=("${C_AMBER}${needs} needs you${C_RESET}")
  (( ready > 0 )) && footer_parts+=("${ready} ready for review")
  (( working_count > 0 )) && footer_parts+=("${C_CYAN}${working_count} working${C_RESET}")
  (( idle_count > 0 )) && footer_parts+=("${C_GREY}${idle_count} idle${C_RESET}")

  local footer=""
  local i
  for (( i=0; i<${#footer_parts[@]}; i++ )); do
    if (( i > 0 )); then
      footer+=" · "
    fi
    footer+="${footer_parts[$i]}"
  done

  echo "  $footer"
  echo ""

  # Gamification: stats tally
  if _tend_gamification_enabled; then
    _tend_gamification_footer
    echo ""
  fi
}

# --- tend <project> (detail view) ---
_tend_cmd_detail() {
  local project_name="$1"
  local project_path=""
  local is_relay_only=false

  # Try to resolve as a local project
  if project_path=$(_tend_resolve_project_path "$project_name" 2>/dev/null); then
    project_name=$(basename "$project_path")
  elif [[ -n "$project_name" && -f "$TEND_RELAY_CACHE_DIR/$project_name" ]]; then
    is_relay_only=true
  else
    echo >&2 "tend: cannot resolve project '$project_name'"
    exit 1
  fi

  local state="" msg="" ts="" icon="" color="" active_count=0

  if ! $is_relay_only; then
    if _tend_project_state "$project_path"; then
      state="$TEND_AGG_STATE"
      msg="$TEND_AGG_MSG"
      ts="$TEND_AGG_TS"
      active_count="$TEND_AGG_ACTIVE"
    fi
  else
    if _tend_relay_project_state "$project_name"; then
      state="$TEND_AGG_STATE"
      msg="$TEND_AGG_MSG"
      ts="$TEND_AGG_TS"
      active_count="$TEND_AGG_ACTIVE"
    fi
  fi

  icon=$(_tend_state_icon "$state")
  color=$(_tend_state_color "$state")

  local upper_name
  upper_name=$(echo "$project_name" | tr '[:lower:]' '[:upper:]')

  local label
  label=$(_tend_state_label "$state")
  if (( active_count > 1 )); then
    label="${active_count} ${state}"
  fi

  echo ""
  echo "  ${C_BOLD}${upper_name}${C_RESET}                               $color$icon $label${C_RESET}"
  echo ""

  # Current task
  if [[ -n "$msg" ]]; then
    echo "  Current: $msg"
  fi
  if [[ -n "$ts" ]]; then
    local ago
    ago=$(_tend_ago "$ts")
    echo "  Since:   $ts (${ago} ago)"
  fi

  if ! $is_relay_only; then
    # Branch
    local branch
    branch=$(git -C "$project_path" branch --show-current 2>/dev/null) || true
    if [[ -n "$branch" ]]; then
      echo "  Branch:  $branch"
    fi

    # Recent commits count (today)
    local commit_count
    commit_count=$(git -C "$project_path" log --oneline --since="midnight" 2>/dev/null | wc -l | tr -d ' ') || true
    if [[ -n "$commit_count" && "$commit_count" != "0" ]]; then
      echo "  Commits: $commit_count today"
    fi
  fi

  # --- Session breakdown ---
  # Gather local events
  local local_events=""
  if ! $is_relay_only && [[ -n "$project_path" ]]; then
    local events_file="$project_path/.tend/events"
    if [[ -f "$events_file" ]] && [[ -s "$events_file" ]]; then
      local_events=$(cat "$events_file")
    fi
  fi

  # Gather relay cache events
  local relay_events=""
  local relay_cache="$TEND_RELAY_CACHE_DIR/$project_name"
  if [[ -f "$relay_cache" ]] && [[ -s "$relay_cache" ]]; then
    relay_events=$(cat "$relay_cache")
  fi

  if [[ -n "$local_events" || -n "$relay_events" ]]; then
  echo ""
  echo "  ${C_BOLD}Sessions:${C_RESET}"

  # Parse sessions from local events using awk — output: session_id TAB state TAB ts TAB message TAB source
  local all_sessions=""
  if [[ -n "$local_events" ]]; then
    all_sessions+=$(awk '
      function is_state(s) { return (s == "working" || s == "done" || s == "stuck" || s == "waiting" || s == "idle") }
      {
        ts = $1
        if ($2 == "*") {
          # Reset marker — clear everything
          for (k in sess) delete sess[k]
          for (k in sess_ts) delete sess_ts[k]
          for (k in sess_msg) delete sess_msg[k]
        } else if (is_state($2)) {
          sess["_cli"] = $2; sess_ts["_cli"] = ts
          msg = ""; for (i = 3; i <= NF; i++) msg = (msg ? msg " " $i : $i)
          sess_msg["_cli"] = msg
        } else if (is_state($3)) {
          sess[$2] = $3; sess_ts[$2] = ts
          msg = ""; for (i = 4; i <= NF; i++) msg = (msg ? msg " " $i : $i)
          sess_msg[$2] = msg
        }
      }
      END {
        for (s in sess) {
          m = (sess_msg[s] == "" ? "-" : sess_msg[s])
          printf "%s\t%s\t%s\t%s\tlocal\n", s, sess[s], sess_ts[s], m
        }
      }
    ' <<< "$local_events")
    all_sessions+=$'\n'
  fi

  if [[ -n "$relay_events" ]]; then
    all_sessions+=$(awk '
      function is_state(s) { return (s == "working" || s == "done" || s == "stuck" || s == "waiting" || s == "idle") }
      {
        ts = $1
        if ($2 == "*") {
          for (k in sess) delete sess[k]
          for (k in sess_ts) delete sess_ts[k]
          for (k in sess_msg) delete sess_msg[k]
        } else if (is_state($2)) {
          sess["_cli"] = $2; sess_ts["_cli"] = ts
          msg = ""; for (i = 3; i <= NF; i++) msg = (msg ? msg " " $i : $i)
          sess_msg["_cli"] = msg
        } else if (is_state($3)) {
          sess[$2] = $3; sess_ts[$2] = ts
          msg = ""; for (i = 4; i <= NF; i++) msg = (msg ? msg " " $i : $i)
          sess_msg[$2] = msg
        }
      }
      END {
        for (s in sess) {
          m = (sess_msg[s] == "" ? "-" : sess_msg[s])
          printf "%s\t%s\t%s\t%s\trelay\n", s, sess[s], sess_ts[s], m
        }
      }
    ' <<< "$relay_events")
  fi

  # Render each session
  local session_count=0
  while IFS=$'\t' read -r sid state ts msg source; do
    [[ -z "$sid" ]] && continue
    (( session_count++ ))

    # Strip placeholder for empty messages
    [[ "$msg" == "-" ]] && msg=""

    # Demote stale working sessions to idle
    if [[ "$state" == "working" && -n "$ts" ]] && _tend_is_stale "$ts"; then
      state="idle"
    fi

    local icon color label
    icon=$(_tend_state_icon "$state")
    color=$(_tend_state_color "$state")
    label=$(_tend_state_label "$state")

    # Format session ID for display
    local display_sid="$sid"
    if [[ "$sid" == "_cli" ]]; then
      display_sid="cli"
    elif (( ${#sid} > 16 )); then
      display_sid="${sid:0:8}…${sid: -4}"
    fi

    local source_tag=""
    if [[ "$source" == "relay" ]]; then
      source_tag=" ↗"
    fi

    local ago=""
    if [[ -n "$ts" ]]; then
      ago=$(_tend_ago "$ts")
    fi

    printf "    %s%s %-10s  %-20s %s" "$color" "$icon" "$label" "$display_sid$source_tag" "$C_RESET"
    if [[ -n "$msg" ]]; then
      printf "  %s" "$msg"
    fi
    if [[ -n "$ago" ]]; then
      printf "  ${C_GREY}(%s)${C_RESET}" "$ago"
    fi
    echo ""
  done <<< "$all_sessions"

  if (( session_count == 0 )); then
    echo "    No active sessions"
  fi

  fi

  # TODO
  if ! $is_relay_only; then
    local todo_file="$project_path/.tend/TODO"
    if [[ -f "$todo_file" ]] && [[ -s "$todo_file" ]]; then
      echo ""
      echo "  ${C_BOLD}TODO:${C_RESET}"
      local n=1
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local item="$line"
        if [[ "$item" == \\[* ]]; then
          item="${item#*] }"
        fi
        echo "    $n. $item"
        (( n++ ))
      done < "$todo_file"
    fi
  fi

  echo ""
}

# --- tend add ---
_tend_cmd_add() {
  local project_name="" message=""

  # With 2+ args, try first arg as project name; with 1 arg, it's either
  # a project name (show TODOs) or a message (add TODO to current project)
  if [[ $# -ge 2 ]] && _tend_resolve_project_path "$1" &>/dev/null; then
    project_name="$1"
    shift
  elif [[ $# -eq 1 ]] && _tend_resolve_project_path "$1" &>/dev/null; then
    # Single arg that resolves as a project: show its TODOs
    project_name="$1"
    shift
  fi

  message="$*"
  if [[ -z "$message" ]]; then
    # No message: show current TODOs
    local project_path
    project_path=$(_tend_resolve_project_path "$project_name") || exit 1
    project_name=$(basename "$project_path")
    local todo_file="$project_path/.tend/TODO"
    if [[ -f "$todo_file" ]] && [[ -s "$todo_file" ]]; then
      echo "${C_BOLD}TODO ($project_name):${C_RESET}"
      local n=1
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local item="$line"
        if [[ "$item" == \[* ]]; then
          item="${item#*] }"
        fi
        echo "  $n. $item"
        (( n++ ))
      done < "$todo_file"
    else
      echo "No TODOs for $project_name"
    fi
    return
  fi

  local project_path
  project_path=$(_tend_resolve_project_path "$project_name") || exit 1
  project_name=$(basename "$project_path")

  if [[ ! -d "$project_path/.tend" ]]; then
    echo >&2 "tend: .tend/ not initialized in $project_name. Run 'tend init $project_name' first."
    exit 1
  fi

  local ts
  ts=$(_tend_ts_local)
  echo "[$ts] $message" >> "$project_path/.tend/TODO"
  echo "✓ Added to $project_name/TODO"
}

# --- tend ack ---
_tend_cmd_ack() {
  local project_name="${1:-}"
  local project_path
  project_path=$(_tend_resolve_project_path "$project_name") || exit 1
  project_name=$(basename "$project_path")

  if [[ ! -d "$project_path/.tend" ]]; then
    echo >&2 "tend: .tend/ not initialized in $project_name. Run 'tend init' first."
    exit 1
  fi

  local ts
  ts=$(_tend_ts_local)
  echo "$ts * idle" >> "$project_path/.tend/events"
  echo "✓ Acknowledged $project_name"
}

# --- tend switch ---
_tend_cmd_switch() {
  local project_name="${1:-}"
  if [[ -z "$project_name" ]]; then
    echo >&2 "Usage: tend switch <project>"
    exit 1
  fi

  local project_path
  project_path=$(_tend_resolve_project_path "$project_name") || exit 1
  project_name=$(basename "$project_path")

  if command -v code &>/dev/null; then
    code "$project_path" && echo "▶ Focused: $project_name (VSCode)"
  else
    echo >&2 "tend switch: 'code' command not found. Install it from VSCode: Cmd+Shift+P → 'Shell Command: Install'"
    exit 1
  fi
}

# --- tend sync ---
_tend_cmd_sync() {
  local project_name="${1:-}"
  local project_path
  project_path=$(_tend_resolve_project_path "$project_name") || exit 1
  project_name=$(basename "$project_path")

  local todo_file="$project_path/.tend/TODO"

  # Gather data
  local git_log=""
  git_log=$(git -C "$project_path" log --oneline -20 --format="%h %s (%ar)" 2>/dev/null) || true

  local todo_content=""
  [[ -f "$todo_file" ]] && todo_content=$(cat "$todo_file")

  # Generate reconciliation prompt
  cat <<EOF
# Tend Sync — $project_name

Review the state of this project and reconcile TODO with actual git history.

## Recent Git History (last 20 commits)
$git_log

## Current TODO
$todo_content

## Instructions
1. Compare TODO against git history. Are there items that have been completed and should be removed?
2. Are there items in git history that suggest new TODOs?
3. Produce an updated TODO list.
EOF
}

# --- tend hook (lifecycle hooks for VS Code / Claude Code) ---
_tend_hook_session_start() {
  local input
  input=$(cat)
  local project_path
  project_path=$(_tend_resolve_project_path "" 2>/dev/null) || return 0

  local context=""
  local todo_file="$project_path/.tend/TODO"

  if [[ -f "$todo_file" ]] && [[ -s "$todo_file" ]]; then
    local todo_content
    todo_content=$(cat "$todo_file")
    context="Current backlog (.tend/TODO) — propose these to the developer:\n${todo_content}"
  fi

  # Include recent git activity for context
  local git_log
  git_log=$(git -C "$project_path" log --oneline -10 --format="%h %s (%ar)" 2>/dev/null) || true
  if [[ -n "$git_log" ]]; then
    if [[ -n "$context" ]]; then
      context="${context}\n\n"
    fi
    context="${context}Recent commits:\n${git_log}"
  fi

  if [[ -n "$context" ]]; then
    local escaped
    escaped=$(_tend_json_escape "$context")
    printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$escaped"
  fi
}

_tend_hook_user_prompt() {
  local input
  input=$(cat)
  _tend_hook_debug "user-prompt" "$input"
  local project_path
  project_path=$(_tend_resolve_project_path "" 2>/dev/null) || return 0

  if [[ -d "$project_path/.tend" ]]; then
    local session_id
    session_id=$(_tend_extract_session_id "$input")
    local ts
    ts=$(_tend_ts_local)
    if [[ -n "$session_id" ]]; then
      echo "$ts $session_id working" >> "$project_path/.tend/events"
    else
      echo "$ts working" >> "$project_path/.tend/events"
    fi
  fi
}

_tend_hook_stop() {
  local input
  input=$(cat)
  _tend_hook_debug "stop" "$input"

  if printf '%s' "$input" | tr '\n' ' ' | grep -q '"stop_hook_active" *: *true'; then
    return 0
  fi

  local project_path
  project_path=$(_tend_resolve_project_path "" 2>/dev/null) || return 0

  if [[ -d "$project_path/.tend" ]]; then
    local session_id
    session_id=$(_tend_extract_session_id "$input")
    local ts
    ts=$(_tend_ts_local)

    # Only demote to idle if current state is "working".
    # Preserve intentional terminal states (done, stuck, waiting).
    local last_state=""
    if [[ -n "$session_id" ]]; then
      last_state=$(grep " $session_id " "$project_path/.tend/events" 2>/dev/null | tail -1 | awk '{print $3}') || true
    else
      last_state=$(tail -1 "$project_path/.tend/events" 2>/dev/null | awk '{print $2}') || true
    fi

    if [[ "$last_state" == "done" || "$last_state" == "stuck" || "$last_state" == "waiting" ]]; then
      return 0
    fi

    if [[ -n "$session_id" ]]; then
      echo "$ts $session_id idle session ended" >> "$project_path/.tend/events"
    else
      echo "$ts idle session ended" >> "$project_path/.tend/events"
    fi
  fi
}

_tend_cmd_hook() {
  local subcmd="${1:-}"
  case "$subcmd" in
    session-start)  _tend_hook_session_start ;;
    user-prompt)    _tend_hook_user_prompt ;;
    stop)           _tend_hook_stop ;;
    *)
      echo >&2 "Usage: tend hook <session-start|user-prompt|stop>"
      exit 1
      ;;
  esac
}

# --- tend version ---
_tend_cmd_version() {
  echo "tend $TEND_VERSION"
}

# --- tend relay ---
_tend_cmd_relay() {
  local subcmd="${1:-}"
  shift || true

  case "$subcmd" in
    setup)
      local relay_url="${TEND_RELAY_URL}"
      echo "Registering with relay at ${relay_url}..."
      local response
      response=$(curl -s -f --connect-timeout 5 --max-time 15 -X POST "${relay_url}/v1/register" 2>&1) || {
        echo >&2 "tend: failed to reach relay at ${relay_url}"
        exit 1
      }
      local token
      token=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
print(data['token'])
" <<< "$response" 2>/dev/null) || {
        echo >&2 "tend: unexpected response from relay"
        exit 1
      }
      mkdir -p "$(dirname "$TEND_RELAY_TOKEN_FILE")"
      echo "$token" > "$TEND_RELAY_TOKEN_FILE"
      chmod 600 "$TEND_RELAY_TOKEN_FILE"
      echo ""
      echo "✓ Token stored in ${TEND_RELAY_TOKEN_FILE}"
      echo ""
      echo "Your relay token:"
      echo "  $token"
      echo ""
      echo "Set this on remote environments:"
      echo "  export TEND_RELAY_TOKEN=\"$token\""
      echo ""
      ;;
    status)
      local token
      token=$(_tend_relay_token 2>/dev/null) || {
        echo "Relay: not configured"
        echo "Run 'tend relay setup' to register"
        return
      }
      local masked="${token:0:8}...${token: -4}"
      echo "Relay:  ${TEND_RELAY_URL}"
      echo "Token:  ${masked}"
      if [[ -d "$TEND_RELAY_CACHE_DIR" ]]; then
        local cache_count
        cache_count=$(find "$TEND_RELAY_CACHE_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
        echo "Cached: ${cache_count} project(s)"
      else
        echo "Cache:  empty"
      fi
      ;;
    pull)
      local token
      token=$(_tend_relay_token 2>/dev/null) || {
        echo >&2 "tend: relay not configured. Run 'tend relay setup' first."
        exit 1
      }
      echo "Syncing relay events..."
      _tend_relay_sync
      echo "✓ Cache refreshed"
      ;;
    token)
      local token
      token=$(_tend_relay_token 2>/dev/null) || {
        echo >&2 "tend: relay not configured. Run 'tend relay setup' first."
        exit 1
      }
      echo "$token"
      echo ""
      echo "Set in your remote environment (Codespaces, CI, etc.):"
      echo "  export TEND_RELAY_TOKEN=\"$token\""
      ;;
    "")
      echo "Usage: tend relay <setup|status|pull|token>"
      echo ""
      echo "  setup    Register with relay, get a token"
      echo "  status   Show relay configuration"
      echo "  pull     Force-refresh event cache from relay"
      echo "  token    Print raw token (for copying to remote envs)"
      ;;
    *)
      echo >&2 "tend: unknown relay command '$subcmd'"
      echo >&2 "Usage: tend relay <setup|status|pull|token>"
      exit 1
      ;;
  esac
}

# --- tend help ---
_tend_cmd_help() {
  cat <<'EOF'
Tend — What's running? What needs me?

Usage:
  tend                          Show the departures board
  tend <project>                Show project detail + sessions
  tend init [project]           Initialize .tend/ in a project
  tend emit <state> "msg"       Emit an event (working/done/stuck/waiting/idle)
  tend clear [project]          Clear events history for a project
  tend status                   Status indicator (○ ◉N ▲N ◆N)
  tend add [project] "msg"      Add a TODO (or show TODOs if no message)
  tend ack [project]            Clear done/stuck/waiting → idle
  tend switch <project>         Focus VSCode window for project
  tend sync [project]           Generate reconciliation prompt
  tend relay <subcmd>           Relay management (setup|status|pull|token)
  tend hook <subcmd>            Lifecycle hooks (session-start|user-prompt|stop)
  tend version                  Show version
  tend help                     Show this help
EOF
}

# ─── Subcommand Dispatcher ───────────────────────────────────────────────────

main() {
  local cmd="${1:-}"

  case "$cmd" in
    "")        _tend_cmd_board ;;
    init)      shift; _tend_cmd_init "$@" ;;
    emit)      shift; _tend_cmd_emit "$@" ;;
    clear)     shift; _tend_cmd_clear "$@" ;;
    status)    _tend_cmd_status ;;
    add|todo)  shift; _tend_cmd_add "$@" ;;
    ack)       shift; _tend_cmd_ack "$@" ;;
    switch|sw) shift; _tend_cmd_switch "$@" ;;
    sync)      shift; _tend_cmd_sync "$@" ;;
    relay)     shift; _tend_cmd_relay "$@" ;;
    hook)      shift; _tend_cmd_hook "$@" ;;
    version)   _tend_cmd_version ;;
    help|-h|--help) _tend_cmd_help ;;
    *)
      # Check if it's a project name
      if _tend_resolve_project_path "$cmd" &>/dev/null; then
        _tend_cmd_detail "$cmd"
      else
        echo >&2 "tend: unknown command '$cmd'"
        echo >&2 "Run 'tend help' for usage"
        exit 1
      fi
      ;;
  esac
}

main "$@"
